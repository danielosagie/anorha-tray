# =============================================================================
# Pick ONE of the three provider paths below. The tray menu also lets you
# switch at runtime, but you need at least one provider configured.
# =============================================================================

# ---- 1. H Company hosted API (recommended — no GPU infra) -------------------
# Sign up at https://hub.hcompany.ai (Portal-H), generate an API key.
# Pay per token; full-quality model; native reasoning + structured outputs.
HAI_API_KEY=
HCOMPANY_MODEL=holo3-1-35b-a3b

# ---- 2. Modal — self-hosted Holo3 GGUF on L4 GPU ----------------------------
# Set after `modal deploy modal_app.py`. Cheapest 24GB GPU; pay per second
# while a request is in flight; auto-scales to zero after 10 min idle.
MODAL_BASE_URL=https://YOUR-USERNAME--holo3-agent
MODAL_BEARER_TOKEN=

# ---- 3. Local provider (Ollama) — fully offline -----------------------------
# Run `bash scripts/setup-local.sh` once to import the GGUF into Ollama.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=holo3

# =============================================================================
# Account linking (Phase 1) — links this computer to an Anorha account so it
# receives commands from the phone. All three values below are PUBLIC
# (publishable key / public deployment URL / public API host) — safe to commit.
# =============================================================================
# Convex deployment that hosts the browserJobs queue + devices/claimJobs fns.
# MUST be the same deployment the phone writes jobs into (sssync-bknd prod).
VITE_CONVEX_URL=https://merry-buffalo-800.convex.cloud
# Clerk PROD instance (clerk.app.anorha.app) — token must validate against the
# backend Convex auth.config issuer. Same instance the mobile app uses.
CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsuYXBwLmFub3JoYS5hcHAk
# Backend API host — used at link time to resolve the account's active org
# (GET /api/organizations/me/active, Bearer <clerk token>), mirroring mobile.
PONDER_API_BASE_URL=https://api.sssync.app

# ── Composite mode: smart hosted planner + Holo3 grounder ─────────────
# (Surfer-2 split.) When set, plan() goes to a cheap frontier-class
# model and Holo3 only grounds descriptions → coordinates. The local
# Ollama router + hierarchical planner are bypassed. Strongly
# recommended — every observed planning failure (loops, hallucinated
# UI, never emitting DONE) came from small models planning.
#
# Easiest: a free Gemini key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Default model is gemini-2.5-flash-lite (≈$0.10/M in, $0.40/M out —
# fractions of a cent per agent step, image included).
#PLANNER_MODEL=gemini-2.5-flash-lite
# Or any OpenAI-compatible endpoint instead of Gemini:
#PLANNER_API_BASE=https://openrouter.ai/api/v1
#PLANNER_API_KEY=
# Text-only planning (cheaper; blind on native-app surfaces):
#PLANNER_VISION=off
# Kill switch:
#PONDER_PLANNER=off
